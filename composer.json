{
    "name": "tommander/blogsimple",
    "description": "blogsimple",
    "license": "CC0-1.0",
    "authors": [
        {
            "name": "tommander",
            "email": "8601794+tommander@users.noreply.github.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Tommander\\BlogSimple\\": "system/src/"
        }
    },
    "scripts": {
        "self:check": "composer validate --strict",
        "donotuse": "by-issue-level, checkstyle, codeclimate, compact, console, count, emacs, github, json, json-summary, junit, phpstorm, pylint, sarif, sonarqube, text, xml",
        "donotuse2": "full, xml, checkstyle, csv, json, junit, emacs, source, summary, diff, svnblame, gitblame, hgblame, notifysend, performance",
        "php:lint": "php -l public/index.php public/endpoint.php system/src/*.php system/partials/*.php",
        "phpcs": "phpcs -p -s --colors --no-cache --report=full",
        "psalm": "psalm --show-info=true --no-file-cache --no-reflection-cache --no-cache --output-format=compact",
        "qa": [
            "@self:check",
            "@php:lint",
            "@phpcs",
            "@psalm"
        ]
    },
    "require-dev": {
        "psr/log": "^3.0",
        "vimeo/psalm": "^6.15",
        "squizlabs/php_codesniffer": "^3.0",
        "phpcompatibility/php-compatibility": "^9.3"
    },
    "require": {
        "league/commonmark": "^2.8"
    }
}
